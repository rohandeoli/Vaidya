# Copy this file to .env.local and fill in any secrets.
# .env.local is gitignored — never commit it.

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://vaidya:localdev@localhost:5432/vaidya

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AWS (LocalStack for local dev) ──────────────────────────
# When AWS_ENDPOINT_URL is set, boto3 routes all calls to LocalStack.
# Unset it (or remove from .env.local) to target real AWS.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── S3 ──────────────────────────────────────────────────────
S3_BUCKET=medical-ai-reports-local

# ── SQS ─────────────────────────────────────────────────────
SQS_OCR_QUEUE_URL=http://localhost:4566/000000000000/medical-ai-ocr-jobs-local
SQS_EXTRACTION_QUEUE_URL=http://localhost:4566/000000000000/medical-ai-extraction-jobs-local
